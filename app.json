{
  "expo": {
    "name": "Sun Se Suraksha",
    "slug": "sunsesuraksha",
    "version": "1.10.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sunsesuraksha",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9F3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sunsesuraksha.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sun Se Suraksha needs your location to show local weather and heat alerts for your city."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF9F3"
      },
      "package": "com.sunsesuraksha.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "versionCode": 12
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sun Se Suraksha needs your location to show local weather and heat alerts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/favicon.png",
          "color": "#D4763C"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5b698eb8-d616-4c59-9e39-eb5a9857a63e"
      }
    }
  }
}
