{
  "expo": {
    "name": "SunSuraksha",
    "slug": "sunsuraksha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sunsuraksha",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9F3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sunsuraksha.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF9F3"
      },
      "package": "com.sunsuraksha.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86867493-a44e-4ecc-887b-e98cd2889a48"
      }
    }
  }
}
